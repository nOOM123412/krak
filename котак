@dp.callback_query(F.data.startswith("cat_"))
async def category_items(callback: types.CallbackQuery):
    cat_id = callback.data.split("_")[1]
    if cat_id == "yoda":
        await callback.answer("Этот магазин временно недоступен из-за нарушения правил площадки.", show_alert=True)
        return
    items = CATEGORIES[cat_id]["items"]
    kb = InlineKeyboardBuilder()
    for code, info in items.items():
        kb.row(types.InlineKeyboardButton(text=f"{info[0]} — {info[1]}₽", callback_data=f"view_{cat_id}:{code}"))
    kb.row(types.InlineKeyboardButton(text="◀ К списку магазинов", callback_data="show_shops"))
    await callback.message.edit_text(f"Товары в категории <b>{CATEGORIES[cat_id]['name']}</b>:", reply_markup=kb.as_markup(), parse_mode="HTML")

@dp.callback_query(F.data.startswith("view_"))
async def product_card(callback: types.CallbackQuery):
    data_parts = callback.data.split("_")[1].split(":")
    cat_id, item_id = data_parts[0], data_parts[1]
    name, price, desc = ALL_ITEMS[item_id]
    kb = InlineKeyboardBuilder()
    kb.row(types.InlineKeyboardButton(text="📥 В корзину", callback_data=f"buy_{item_id}"))
    kb.row(types.InlineKeyboardButton(text="◀ Назад", callback_data=f"cat_{cat_id}"))
    text = f"<b>{name}</b>\n\n{desc}\n\n💰 Цена: <b>{price}₽</b>"
    photo_path = os.path.join(SHARED_DIR, f"{item_id}.jpg")
    if os.path.exists(photo_path):
        await callback.message.answer_photo(FSInputFile(photo_path), caption=text, reply_markup=kb.as_markup(), parse_mode="HTML")
        await callback.message.delete()
    else:
        await callback.message.edit_text(text + "\n\n<i>(Фото отсутствует)</i>", reply_markup=kb.as_markup(), parse_mode="HTML")

@dp.callback_query(F.data.startswith("buy_"))
async def add_to_cart_handler(callback: types.CallbackQuery):
    item_id = callback.data.split("_")[1]
    await manage_cart("add", callback.from_user.id, item_id)
    await callback.answer(f"✅ {ALL_ITEMS[item_id][0]} добавлен!")

@dp.callback_query(F.data == "show_cart")
async def display_cart(callback: types.CallbackQuery):
    items = await manage_cart("get", callback.from_user.id)
    if not items:
        await callback.answer("Корзина пуста!", show_alert=True)
        return
    total = sum(ALL_ITEMS[i][1] for i in items if i in ALL_ITEMS)
    res_text = "<b>🧺 Ваша корзина:</b>\n\n" + "\n".join([f"• {ALL_ITEMS[i][0]} — {ALL_ITEMS[i][1]}₽" for i in items if i in ALL_ITEMS])
    res_text += f"\n\nИТОГО: <b>{total}₽</b>"
    kb = InlineKeyboardBuilder()
    kb.row(types.InlineKeyboardButton(text="💳 Оплатить", callback_data="p2p_menu"))
    kb.row(types.InlineKeyboardButton(text="🗑 Очистить", callback_data="clear_cart"))
    kb.row(types.InlineKeyboardButton(text="◀ В меню", callback_data="to_main"))
    await callback.message.answer(res_text, reply_markup=kb.as_markup(), parse_mode="HTML")

