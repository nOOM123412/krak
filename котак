@dp.callback_query(F.data == "show_cart")
async def display_cart(callback: types.CallbackQuery):
    items = await manage_cart("get", callback.from_user.id)
    if not items:
        await callback.answer("Ваша корзина пока пуста!", show_alert=True)
        return
    total = sum(ALL_ITEMS[i][1] for i in items if i in ALL_ITEMS)
    res_text = "<b>🧺 Содержимое корзины:</b>\n\n" + "\n".join([f"• {ALL_ITEMS[i][0]} — {ALL_ITEMS[i][1]}₽" for i in items if i in ALL_ITEMS])
    res_text += f"\n\nК оплате: <b>{total}₽</b>"
    kb = InlineKeyboardBuilder()
    kb.row(types.InlineKeyboardButton(text="💳 Перейти к оплате", callback_data="p2p_menu"))
    kb.row(types.InlineKeyboardButton(text="🗑 Очистить корзину", callback_data="clear_cart"))
