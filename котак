@dp.callback_query(F.data == "show_cart")
async def display_cart(callback: types.CallbackQuery):
    items = await manage_cart("get", callback.from_user.id)
    if not items:
        await callback.answer("Корзина пуста!", show_alert=True)
        return
    
    total = sum(ALL_ITEMS[i][1] for i in items if i in ALL_ITEMS)
    res_text = "<b>🧺 Ваша корзина:</b>\n\n"
    for i in items:
        if i in ALL_ITEMS:
            res_text += f"• {ALL_ITEMS[i][0]} — {ALL_ITEMS[i][1]}₽\n"
    res_text += f"\nИТОГО К ОПЛАТЕ: <b>{total}₽</b>"
    
    kb = InlineKeyboardBuilder()
    kb.row(types.InlineKeyboardButton(text="💳 Оплатить (USDT)", callback_data="pay_now"))
    kb.row(types.InlineKeyboardButton(text="🗑 Очистить", callback_data="clear_cart"))
    kb.row(types.InlineKeyboardButton(text="◀ Меню", callback_data="to_main"))
    
    await callback.message.answer(res_text, reply_markup=kb.as_markup(), parse_mode="HTML")

@dp.callback_query(F.data == "pay_now")
async def pay_handler(callback: types.CallbackQuery):
    items = await manage_cart("get", callback.from_user.id)
    total = sum(ALL_ITEMS[i][1] for i in items if i in ALL_ITEMS)
    
    url = await create_invoice(total)
    if url:
        kb = InlineKeyboardBuilder()
        kb.row(types.InlineKeyboardButton(text="🚀 Перейти к оплате", url=url))
        await callback.message.answer(f"Счет на сумму {total}₽ сформирован в USDT.\nНажмите кнопку для оплаты в CryptoBot:", reply_markup=kb.as_markup())
    else:
        await callback.answer("Ошибка платежной системы. Попробуйте позже.")

