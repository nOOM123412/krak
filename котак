@dp.callback_query(F.data.startswith("view_"))
async def product_card(callback: types.CallbackQuery):
    item_id = callback.data.replace("view_", "")
    if item_id not in ALL_ITEMS: return
    
    name, price, desc = ALL_ITEMS[item_id]
    
    # Поиск ID категории для кнопки Назад
    back_cat = "show_shops"
    for c_id, c_data in CATEGORIES.items():
        if item_id in c_data["items"]:
            back_cat = f"cat_{c_id}"
            break

    kb = InlineKeyboardBuilder()
    kb.row(types.InlineKeyboardButton(text="📥 Купить", callback_data=f"buy_{item_id}"))
    kb.row(types.InlineKeyboardButton(text="◀ Назад", callback_data=back_cat))
    
    text = f"📦 **{name}**\n\n{desc}\n\n💰 Стоимость: **{price}₽**"
    
    photo_path = os.path.join(SHARED_DIR, f"{item_id}.jpg")
    if os.path.exists(photo_path):
        await callback.message.answer_photo(FSInputFile(photo_path), caption=text, reply_markup=kb.as_markup(), parse_mode="Markdown")
        await callback.message.delete()
    else:
        await callback.message.edit_text(text, reply_markup=kb.as_markup(), parse_mode="Markdown")

@dp.callback_query(F.data.startswith("buy_"))
async def add_to_cart_handler(callback: types.CallbackQuery):
    item_id = callback.data.replace("buy_", "")
    await manage_cart("add", callback.from_user.id, item_id)
    await callback.answer(f"✅ {ALL_ITEMS[item_id][0]} добавлен!")

@dp.callback_query(F.data == "show_cart")
async def display_cart(callback: types.CallbackQuery):
    items = await manage_cart("get", callback.from_user.id)
    if not items:
        await callback.answer("Ваша корзина пуста!", show_alert=True)
        return
    total = sum(ALL_ITEMS[i][1] for i in items if i in ALL_ITEMS)
    res_text = "🧺 **Содержимое корзины:**\n\n" + "\n".join([f"• {ALL_ITEMS[i][0]} — **{ALL_ITEMS[i][1]}₽**" for i in items if i in ALL_ITEMS])
    res_text += f"\n\nИтого к оплате: **{total}₽**"
    kb = InlineKeyboardBuilder()
    kb.row(types.InlineKeyboardButton(text="💳 Оплатить заказ", callback_data="p2p_menu"))
    kb.row(types.InlineKeyboardButton(text="🗑 Очистить корзину", callback_data="clear_cart"))
    kb.row(types.InlineKeyboardButton(text="◀ Главное меню", callback_data="to_main"))
    await callback.message.answer(res_text, reply_markup=kb.as_markup(), parse_mode="Markdown")

@dp.callback_query(F.data == "to_main")
async def back_to_main(callback: types.CallbackQuery):
    kb = InlineKeyboardBuilder()
    kb.row(types.InlineKeyboardButton(text="🛍 Магазины", callback_data="show_shops"), 
           types.InlineKeyboardButton(text="🧺 Корзина", callback_data="show_cart"))
    await callback.message.answer("🛒 **Главное меню:**", reply_markup=kb.as_markup(), parse_mode="Markdown")
    try: await callback.message.delete()
    except: pass

