# Обработчик: Crypto TRC20
@dp.callback_query(F.data == "pay_trc20")
async def pay_trc20_handler(callback: types.CallbackQuery):
    items = await manage_cart("get", callback.from_user.id)
    if not items: return
    total = sum(ALL_ITEMS[i][1] for i in items if i in ALL_ITEMS)
    
    invoice_url = await create_invoice(total)
    if invoice_url:
        kb = InlineKeyboardBuilder()
        kb.row(types.InlineKeyboardButton(text="🚀 Оплатить в USDT", url=invoice_url))
        await callback.message.answer(
            f"Сумма: <b>{total}₽</b> (~{round(total/EXCHANGE_RATE, 2)} USDT)\n"
            f"Сеть: <b>TRC20</b>\n\n"
            "Нажмите кнопку ниже, чтобы получить адрес кошелька:",
            reply_markup=kb.as_markup(), parse_mode="HTML"
        )
    else:
        await callback.answer("Ошибка связи с платежным шлюзом.")

