    if callback.message.photo:
        await callback.message.delete()

async def main():
    if not os.path.exists(SHARED_DIR):
        os.makedirs(SHARED_DIR)
    init_db()
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
